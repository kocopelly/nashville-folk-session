{# Renders a single set. Expects: set, tunes, isLoose (single-tune no-label) #}
{% if isLoose %}
  {# Single tune, no label — compact line with left accent #}
  <div class="border-l-2 border-border pl-3 py-1">
    <div class="text-[15px]">
      {% set entry = set.tunes[0] %}
      {% set link = entry | tuneLink(tunes) %}
      {% if link %}<a href="{{ link }}" target="_blank" rel="noopener" class="text-ink hover:bg-accent-dim transition-colors font-semibold border-b border-border">{{ entry | tuneName(tunes) }}</a>{% else %}<span class="font-semibold">{{ entry | tuneName(tunes) }}</span>{% endif %}
      <span class="text-xs text-muted">({{ entry | tuneKey | default(entry | tuneType(tunes)) }})</span>
    </div>
    {% if set.notes %}
      <div class="text-xs text-muted italic mt-0.5">{{ set.notes }}</div>
    {% endif %}
  </div>
{% else %}
  {# Multi-tune or labeled set — left accent border with inline tunes #}
  <div class="border-l-2 border-accent pl-3 py-1.5">
    {% if set.label %}<div class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted mb-1">{{ set.label }}</div>{% endif %}
    <div class="text-[15px] leading-relaxed">
      {% for entry in set.tunes %}
        {% set link = entry | tuneLink(tunes) %}
        {% if link %}<a href="{{ link }}" target="_blank" rel="noopener" class="text-ink hover:bg-accent-dim transition-colors font-semibold border-b border-border">{{ entry | tuneName(tunes) }}</a>{% else %}<span class="font-semibold">{{ entry | tuneName(tunes) }}</span>{% endif %}
        <span class="text-xs text-muted">({{ entry | tuneKey | default(entry | tuneType(tunes)) }})</span>{% if not loop.last %} <span class="text-muted">/</span> {% endif %}
      {% endfor %}
    </div>
    {% if set.notes or (set.links and set.links.length) %}
      <div class="flex flex-wrap items-center gap-2 mt-1">
        {% if set.notes %}<span class="text-xs text-muted italic">{{ set.notes }}</span>{% endif %}
        {% if set.links and set.links.length %}
          {% for link in set.links %}
            <a href="{{ link.url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest px-2 py-0.5 border border-border text-ink bg-bg hover:border-ink transition-colors">{{ link.type | linkEmoji }} {{ link.label }}</a>
          {% endfor %}
        {% endif %}
      </div>
    {% endif %}
  </div>
{% endif %}
