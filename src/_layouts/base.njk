<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Nashville Folk Session") }}</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%231a1a3a'><path d='M11 2a1 1 0 0 0-1 1v6a.5.5 0 0 0 .5.5H12a.5.5 0 0 1 .5.5a.5.5 0 0 1-.5.5h-1.5C9.73 10.5 9 9.77 9 9V5.16C7.27 5.6 6 7.13 6 9v1.5A2.5 2.5 0 0 1 8.5 13A2.5 2.5 0 0 1 6 15.5V17c0 2.77 2.23 5 5 5h2c2.77 0 5-2.23 5-5v-1.5a2.5 2.5 0 0 1-2.5-2.5a2.5 2.5 0 0 1 2.5-2.5V9c0-2.22-1.78-4-4-4V3a1 1 0 0 0-1-1zm-.25 14.5h2.5l-.5 3.5h-1.5z'/></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body class="bg-bg text-ink min-h-screen flex flex-col leading-relaxed">
  <header class="border-b-2 border-ink">
    <nav class="max-w-2xl mx-auto px-4 py-6">
      <div class="text-center mb-3">
        <a href="/" class="font-display text-3xl font-black text-ink no-underline uppercase tracking-widest">
          Nashville Folk Session
        </a>
      </div>
      {% set u = page.url %}
      <div class="flex justify-center gap-4 sm:gap-8 border-t border-border pt-3">
        <a href="/" class="text-xs uppercase tracking-widest no-underline transition-colors font-semibold {% if u == '/' or '/sessions/' in u %}text-ink border-b border-ink pb-0.5{% else %}text-muted hover:text-ink{% endif %}">Sessions</a>
        <a href="/series/" class="text-xs uppercase tracking-widest no-underline transition-colors font-semibold {% if '/series/' in u %}text-ink border-b border-ink pb-0.5{% else %}text-muted hover:text-ink{% endif %}">Series</a>
        <a href="/tunes/" class="text-xs uppercase tracking-widest no-underline transition-colors font-semibold {% if u == '/tunes/' %}text-ink border-b border-ink pb-0.5{% else %}text-muted hover:text-ink{% endif %}">Tunes</a>
        <a href="/stats/" class="text-xs uppercase tracking-widest no-underline transition-colors font-semibold {% if u == '/stats/' %}text-ink border-b border-ink pb-0.5{% else %}text-muted hover:text-ink{% endif %}">Stats</a>
        <a href="/about/" class="text-xs uppercase tracking-widest no-underline transition-colors font-semibold {% if u == '/about/' %}text-ink border-b border-ink pb-0.5{% else %}text-muted hover:text-ink{% endif %}">About</a>
      </div>
    </nav>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-10 flex-1 w-full">
    {{ content | safe }}
  </main>

  <footer class="border-t-2 border-ink py-6 px-4 text-center text-muted text-xs uppercase tracking-widest">
    <p>Nashville Folk Session · curated by <a href="https://github.com/slime-the-bot" class="text-ink hover:underline">Slime</a></p>
  </footer>
</body>
</html>
