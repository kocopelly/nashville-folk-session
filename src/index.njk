---
layout: base.njk
title: Sessions — Nashville Folk Session
---

<div class="text-center mb-10">
  <h1 class="font-display text-4xl font-black uppercase tracking-wider mb-1">Sessions</h1>
  <div class="w-16 h-0.5 bg-ink mx-auto"></div>
</div>

{% if sessions.length === 0 %}
  <p class="text-center text-muted py-12 text-lg">No sessions logged yet. Send Slime your set list! 🎻</p>
{% else %}
  <div class="space-y-10">
    {% for session in sessions | reverse %}
    <article class="pb-10 {% if not loop.last %}border-b border-border{% endif %}">
      <div class="flex flex-wrap items-baseline gap-3 mb-2">
        <h2 class="font-display text-2xl font-bold">{{ session.date | dateDisplay }}</h2>
        {% set tradition = session | resolve("tradition", series) %}
        {% if tradition %}
          <span class="badge-{{ tradition }} text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-sm">{{ tradition }}</span>
        {% endif %}
      </div>

      {% set venue = session | resolve("venue", series) %}
      {% set location = session | resolve("location", series) %}
      {% set seriesName = series[session.seriesId].name if series[session.seriesId] else null %}
      {% set organizer = session | resolve("organizer", series) %}
      <div class="text-sm text-muted mb-6 flex flex-wrap gap-x-3 gap-y-1">
        {% if venue %}<span>{{ venue }}{% if location %}, {{ location }}{% endif %}</span>{% endif %}
        {% if seriesName %}<span>·</span><span class="font-semibold text-ink">{{ seriesName }}</span>{% endif %}
        {% if organizer %}<span>·</span><span>{{ organizer }}</span>{% endif %}
      </div>

      <div class="space-y-5">
        {% for set in session.sets %}
        <div>
          <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted mb-2 border-b border-border pb-1">
            Set {{ loop.index }}{% if set.label %} — {{ set.label }}{% endif %}
          </div>
          <ol class="list-decimal list-inside space-y-1">
            {% for entry in set.tunes %}
              <li class="text-[15px]">
                {% set link = entry | tuneLink(tunes) %}
                {% if link %}<a href="{{ link }}" target="_blank" rel="noopener" class="text-ink hover:bg-accent-dim transition-colors font-semibold border-b border-border">{{ entry | tuneName(tunes) }}</a>{% else %}<span class="font-semibold">{{ entry | tuneName(tunes) }}</span>{% endif %}
                <span class="text-xs text-muted ml-1">{{ entry | tuneType(tunes) }}{% if entry | tuneKey %} · {{ entry | tuneKey }}{% endif %}</span>
              </li>
            {% endfor %}
          </ol>
          {% if set.notes %}<p class="text-sm text-muted italic mt-2">{{ set.notes }}</p>{% endif %}
          {% if set.links and set.links.length %}
            <div class="flex flex-wrap gap-2 mt-2">
              {% for link in set.links %}
                <a href="{{ link.url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest px-3 py-1 border border-border text-ink bg-bg hover:border-ink transition-colors">{{ link.type | linkEmoji }} {{ link.label }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>

      {% if session.notes %}<p class="text-sm text-muted italic mt-6 pt-4 border-t border-border">{{ session.notes }}</p>{% endif %}
      {% if session.links and session.links.length %}
        <div class="flex flex-wrap gap-2 mt-4">
          {% for link in session.links %}
            <a href="{{ link.url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest px-3 py-1 border border-border text-ink bg-bg hover:border-ink transition-colors">{{ link.type | linkEmoji }} {{ link.label }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </article>
    {% endfor %}
  </div>
{% endif %}
