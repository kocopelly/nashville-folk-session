---
layout: base.njk
title: Sessions — Nashville Folk Session
---

<div class="text-center mb-10">
  <h1 class="font-display text-4xl font-black uppercase tracking-wider mb-1">Sessions</h1>
  <div class="w-16 h-0.5 bg-ink mx-auto"></div>
</div>

{% if sessions.length === 0 %}
  <p class="text-center text-muted py-12 text-lg">No sessions logged yet. Send Slime your set list! 🎻</p>
{% else %}
  {% set maxVisible = 3 %}
  <div class="space-y-8">
    {% for session in sessions | reverse %}
    {% set isAllLoose = session.sets | allLoose %}
    <article class="pb-8 {% if not loop.last %}border-b border-border{% endif %}">
      <div class="flex flex-wrap items-baseline gap-3 mb-1">
        <h2 class="font-display text-2xl font-bold">
          <a href="/sessions/{{ session.id }}/" class="text-ink no-underline hover:text-accent transition-colors">{{ session.date | dateDisplay }}</a>
        </h2>
        {% set tradition = session | resolve("tradition", series) %}
        {% if tradition %}
          <span class="badge-{{ tradition }} text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-sm">{{ tradition }}</span>
        {% endif %}
      </div>

      {% set venue = session | resolve("venue", series) %}
      {% set location = session | resolve("location", series) %}
      {% set seriesName = series[session.seriesId].name if series[session.seriesId] else null %}
      {% set organizer = session | resolve("organizer", series) %}
      <div class="text-sm text-muted mb-4 flex flex-wrap gap-x-3 gap-y-1">
        {% if venue %}<span>{{ venue }}{% if location %}, {{ location }}{% endif %}</span>{% endif %}
        {% if seriesName %}<span>·</span><span class="font-semibold text-ink">{{ seriesName }}</span>{% endif %}
        {% if organizer %}<span>·</span><span>{{ organizer }}</span>{% endif %}
        <span>·</span>
        {% if isAllLoose %}
          <span>{{ session.sets | tuneCount }} tunes</span>
        {% else %}
          <span>{{ session.sets.length }} sets</span>
        {% endif %}
      </div>

      {# Visible portion with fade #}
      <div class="session-truncation-wrapper">
        <div class="relative">
          <div class="space-y-2">
            {% for set in session.sets %}
              {% if loop.index0 < maxVisible %}
                {% set isLoose = set | isLoose %}
                {% include "set-item.njk" %}
              {% endif %}
            {% endfor %}
          </div>
          {% if session.sets.length > maxVisible %}
            <div class="truncation-fade"></div>
          {% endif %}
        </div>

        {# Expandable overflow #}
        {% if session.sets.length > maxVisible %}
          <details class="session-details">
            <summary class="text-[10px] font-bold uppercase tracking-[0.2em] text-accent cursor-pointer hover:text-ink transition-colors select-none">
              {% if isAllLoose %}
                <span class="details-show-more">Show {{ session.sets.length - maxVisible }} more tune{{ "s" if (session.sets.length - maxVisible) > 1 }} ▾</span>
              {% else %}
                <span class="details-show-more">Show {{ session.sets.length - maxVisible }} more set{{ "s" if (session.sets.length - maxVisible) > 1 }} ▾</span>
              {% endif %}
              <span class="details-show-less">Show less ▴</span>
            </summary>
            <div class="space-y-2 mt-2">
              {% for set in session.sets %}
                {% if loop.index0 >= maxVisible %}
                  {% set isLoose = set | isLoose %}
                  {% include "set-item.njk" %}
                {% endif %}
              {% endfor %}
            </div>
          </details>
        {% endif %}
      </div>

      {# Footer #}
      <div class="flex items-center gap-4 mt-3">
        {% if session.links and session.links.length %}
          {% for link in session.links %}
            <a href="{{ link.url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest px-3 py-1 border border-border text-ink bg-bg hover:border-ink transition-colors">{{ link.type | linkEmoji }} {{ link.label }}</a>
          {% endfor %}
        {% endif %}
        <a href="/sessions/{{ session.id }}/" class="inline-flex items-center gap-1 text-[10px] uppercase tracking-[0.2em] font-bold text-accent hover:text-ink transition-colors ml-auto">View session →</a>
      </div>
    </article>
    {% endfor %}
  </div>
{% endif %}
