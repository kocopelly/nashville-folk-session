---
layout: base.njk
title: Sessions — Nashville Folk Session
---

<div class="text-center mb-10">
  <h1 class="font-display text-4xl font-black uppercase tracking-wider mb-1">Sessions</h1>
  <div class="w-16 h-0.5 bg-ink mx-auto"></div>
</div>

{% if sessions.length === 0 %}
  <p class="text-center text-muted py-12 text-lg">No sessions logged yet. Send Slime your set list! 🎻</p>
{% else %}
  {% set maxVisible = 3 %}
  <div class="space-y-8">
    {% for session in sessions | reverse %}
    {% set isAllLoose = session.sets | allLoose %}
    <article class="pb-8 {% if not loop.last %}border-b border-border{% endif %}">
      <div class="flex flex-wrap items-baseline gap-3 mb-1">
        <h2 class="font-display text-3xl font-bold">
          <a href="/sessions/{{ session.id }}/" class="text-ink no-underline hover:text-accent transition-colors">{{ session.date | dateDisplay }}</a>
        </h2>
        {% set tradition = session | resolve("tradition", series) %}
        {% if tradition %}
          <span class="badge-{{ tradition }} text-xs font-bold uppercase tracking-widest px-2 py-0.5 rounded-sm">{{ tradition }}</span>
        {% endif %}
      </div>

      {% set venue = session | resolve("venue", series) %}
      {% set location = session | resolve("location", series) %}
      {% set seriesName = series[session.seriesId].name if series[session.seriesId] else null %}
      {% set organizer = session | resolve("organizer", series) %}
      <dl class="text-sm text-muted mb-4 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
        {% if venue %}
          <dt class="font-medium text-ink">Venue</dt>
          <dd>{{ venue }}{% if location %}, {{ location }}{% endif %}</dd>
        {% endif %}
        {% if seriesName %}
          <dt class="font-medium text-ink">Series</dt>
          <dd><a href="/series/{{ session.seriesId }}/" class="text-muted hover:text-ink transition-colors underline decoration-border hover:decoration-ink">{{ seriesName }}</a></dd>
        {% endif %}
        {% if organizer %}
          <dt class="font-medium text-ink">Led by</dt>
          <dd>{{ organizer }}</dd>
        {% endif %}
        <dt class="font-medium text-ink">{% if isAllLoose %}Tunes{% else %}Sets{% endif %}</dt>
        <dd>{% if isAllLoose %}{{ session.sets | tuneCount }}{% else %}{{ session.sets.length }}{% endif %}</dd>
      </dl>

      {# Visible portion with fade #}
      <div class="session-truncation-wrapper">
        <div class="relative">
          <div class="space-y-2">
            {% for set in session.sets %}
              {% if loop.index0 < maxVisible %}
                {% set isLoose = set | isLoose %}
                {% include "set-item.njk" %}
              {% endif %}
            {% endfor %}
          </div>
          {% if session.sets.length > maxVisible %}
            <div class="truncation-fade"></div>
          {% endif %}
        </div>

        {# Expandable overflow #}
        {% if session.sets.length > maxVisible %}
          <div class="flex items-start gap-4">
            <details class="session-details flex-1">
              <summary class="text-xs font-bold uppercase tracking-widest text-accent cursor-pointer hover:text-ink transition-colors select-none">
                {% if isAllLoose %}
                  <span class="details-show-more">Show {{ session.sets.length - maxVisible }} more tune{{ "s" if (session.sets.length - maxVisible) > 1 }} ▾</span>
                {% else %}
                  <span class="details-show-more">Show {{ session.sets.length - maxVisible }} more set{{ "s" if (session.sets.length - maxVisible) > 1 }} ▾</span>
                {% endif %}
                <span class="details-show-less">Show less ▴</span>
              </summary>
              <div class="space-y-2 mt-2">
                {% for set in session.sets %}
                  {% if loop.index0 >= maxVisible %}
                    {% set isLoose = set | isLoose %}
                    {% include "set-item.njk" %}
                  {% endif %}
                {% endfor %}
              </div>
            </details>
            <a href="/sessions/{{ session.id }}/" class="shrink-0 text-xs font-bold uppercase tracking-widest text-accent hover:text-ink transition-colors">View session →</a>
          </div>
        {% endif %}
      </div>

      {# Footer — only shown for sessions with ≤ maxVisible sets #}
      {% if session.sets.length <= maxVisible %}
        <div class="flex items-center gap-4 mt-3">
          {% if session.links and session.links.length %}
            {% for link in session.links %}
              <a href="{{ link.url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs uppercase tracking-widest px-3 py-1 border border-border text-ink bg-bg hover:border-ink transition-colors">{{ link.type | linkIcon | safe }} {{ link.label | replace("TheSession set", "thesession.org") }}</a>
            {% endfor %}
          {% endif %}
          <a href="/sessions/{{ session.id }}/" class="inline-flex items-center gap-1 text-xs uppercase tracking-widest font-bold text-accent hover:text-ink transition-colors ml-auto">View session →</a>
        </div>
      {% else %}
        {% if session.links and session.links.length %}
          <div class="flex items-center gap-4 mt-2">
            {% for link in session.links %}
              <a href="{{ link.url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs uppercase tracking-widest px-3 py-1 border border-border text-ink bg-bg hover:border-ink transition-colors">{{ link.type | linkIcon | safe }} {{ link.label | replace("TheSession set", "thesession.org") }}</a>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </article>
    {% endfor %}
  </div>
{% endif %}
