---
layout: base.njk
title: "Listen — Nashville Folk Session"
---

<div id="listen-app" class="max-w-lg mx-auto">
  <h1 class="font-display text-2xl font-black uppercase tracking-wider mb-2">Live Listen</h1>
  <p class="text-muted text-sm mb-6">Passive tune ID powered by <a href="https://github.com/TomWyllie/folkfriend" class="underline hover:text-ink transition-colors">FolkFriend</a>. Tap set boundaries and fix misidentifications as you go.</p>

  <!-- Controls -->
  <div class="flex items-center gap-4 mb-4">
    <button id="btn-listen" class="border-2 border-ink px-5 py-2 text-xs uppercase tracking-widest font-semibold hover:bg-ink hover:text-bg transition-colors cursor-pointer active:scale-95">
      Start Listening
    </button>
    <span id="status" class="text-muted text-xs uppercase tracking-widest">Ready</span>
  </div>

  <div class="mb-4 flex items-center gap-4 text-xs text-muted">
    <label class="flex items-center gap-1">Query every
      <select id="query-interval" class="border border-border bg-bg text-ink px-1.5 py-1 rounded-sm cursor-pointer hover:border-ink transition-colors">
        <option value="8">8s</option>
        <option value="12">12s</option>
        <option value="15" selected>15s</option>
        <option value="20">20s</option>
        <option value="30">30s</option>
      </select>
    </label>
    <label class="flex items-center gap-1">Min score
      <input id="min-score" type="number" min="0" max="1" step="0.05" value="0.25"
             class="border border-border bg-bg text-ink px-1.5 py-1 w-16 rounded-sm hover:border-ink transition-colors">
    </label>
  </div>

  <!-- Debug -->
  <div id="debug" class="mb-6 text-xs text-muted font-mono hidden">
    <span id="dbg-frames">frames: 0</span> ·
    <span id="dbg-queries">queries: 0</span> ·
    <span id="dbg-last">last: —</span>
  </div>

  <!-- Tune log -->
  <div id="tune-log"></div>

  <!-- Bottom insert strip -->
  <div id="bottom-strip" class="hidden"></div>

  <!-- Clear -->
  <div id="clear-row" class="hidden mt-8">
    <button id="btn-clear" class="text-xs text-muted hover:text-ink transition-colors cursor-pointer uppercase tracking-widest">
      Clear all
    </button>
  </div>
</div>

<style>
  /* ── Tune row ── */
  .tune-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0;
  }
  .tune-row:hover { background: var(--color-hover); margin: 0 -0.5rem; padding: 0.5rem; border-radius: 3px; }
  .tune-row .tune-actions { opacity: 0; display: flex; gap: 0.25rem; transition: opacity 0.1s; }
  .tune-row:hover .tune-actions { opacity: 1; }

  .tune-link { text-decoration: underline; text-underline-offset: 2px; transition: color 0.1s; }
  .tune-link:hover { color: var(--color-muted); }
  .tune-score { color: var(--color-muted); font-size: 0.75rem; margin-left: 0.25rem; }
  .tune-manual-tag { color: var(--color-muted); font-size: 0.75rem; font-style: italic; margin-left: 0.25rem; }

  .icon-btn {
    background: none; border: none; color: var(--color-muted);
    cursor: pointer; padding: 2px 4px; font-size: 0.6875rem; line-height: 1;
    border-radius: 2px; transition: all 0.1s;
  }
  .icon-btn:hover { color: var(--color-ink); background: var(--color-bg); }

  /* ── Insert strip — always same height, actions fade ── */
  .insert-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 28px;
    gap: 0.375rem;
    position: relative;
  }
  .insert-strip::before {
    content: '';
    position: absolute;
    left: 0; right: 0; top: 50%;
    border-top: 1px dashed transparent;
    transition: border-color 0.15s;
  }
  .insert-strip:hover::before { border-color: var(--color-border); }
  .insert-strip .strip-btn {
    opacity: 0;
    background: var(--color-bg);
    border: 1px solid transparent;
    color: var(--color-muted);
    cursor: pointer;
    padding: 1px 8px;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: all 0.1s;
    position: relative;
    z-index: 1;
    white-space: nowrap;
  }
  .insert-strip:hover .strip-btn { opacity: 1; border-color: var(--color-border); }
  .insert-strip .strip-btn:hover { border-color: var(--color-ink); color: var(--color-ink); }
  .insert-strip .strip-btn:active { background: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink); }

  /* ── Bottom strip: always visible ── */
  .bottom-strip-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.625rem 0;
    border-top: 1px dashed var(--color-border);
    margin-top: 0.25rem;
  }
  .bottom-strip-inner .strip-btn {
    opacity: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    cursor: pointer;
    padding: 3px 10px;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: all 0.1s;
    white-space: nowrap;
  }
  .bottom-strip-inner .strip-btn:hover { border-color: var(--color-ink); color: var(--color-ink); }
  .bottom-strip-inner .strip-btn:active { background: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink); }

  /* ── Divider row ── */
  .divider-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0;
  }
  .divider-line { flex: 1; border-top: 2px solid var(--color-ink); }
  .divider-label { font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); font-weight: 600; user-select: none; white-space: nowrap; }
  .divider-row .icon-btn { opacity: 0; transition: opacity 0.1s; }
  .divider-row:hover .icon-btn { opacity: 1; }

  /* ── Alternatives panel ── */
  .alts-panel {
    margin: 0 0 0.25rem 1.75rem;
    padding: 0.25rem 0;
  }
  .alt-pick {
    display: block; width: 100%; text-align: left;
    background: none; border: none;
    padding: 0.25rem 0.5rem; border-radius: 2px;
    font-size: 0.75rem; color: var(--color-muted);
    cursor: pointer; transition: all 0.1s;
  }
  .alt-pick:hover { color: var(--color-ink); background: var(--color-hover); }

  /* ── Inline manual input ── */
  .inline-input {
    border: 1px solid var(--color-ink);
    background: var(--color-bg);
    color: var(--color-ink);
    padding: 2px 8px;
    font-size: 0.75rem;
    width: 12rem;
    outline: none;
  }
  .inline-input::placeholder { color: var(--color-muted); opacity: 0.5; }
</style>

<script type="module">
  const btn = document.getElementById('btn-listen');
  const statusEl = document.getElementById('status');
  const tuneLogEl = document.getElementById('tune-log');
  const bottomStrip = document.getElementById('bottom-strip');
  const clearRow = document.getElementById('clear-row');
  const intervalSel = document.getElementById('query-interval');
  const minScoreInput = document.getElementById('min-score');
  const debugEl = document.getElementById('debug');
  const dbgFrames = document.getElementById('dbg-frames');
  const dbgQueries = document.getElementById('dbg-queries');
  const dbgLast = document.getElementById('dbg-last');
  const btnClear = document.getElementById('btn-clear');

  let listening = false, worker = null, audioCtx = null, micStream = null;
  let queryTimer = null, workerReady = false, framesSent = 0, queriesSent = 0;
  let items = [];

  function setStatus(msg) { statusEl.textContent = msg; }
  function updateDebug(last) {
    dbgFrames.textContent = `frames: ${framesSent}`;
    dbgQueries.textContent = `queries: ${queriesSent}`;
    if (last !== undefined) dbgLast.textContent = `last: ${last}`;
  }

  function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  function tuneNumber(idx) {
    if (items[idx]?.type !== 'tune') return '';
    let n = 0;
    for (let i = 0; i <= idx; i++) if (items[i].type === 'tune') n++;
    return n + '.';
  }

  // ── Strip HTML ──
  function stripHTML(idx) {
    return `<div class="insert-strip" data-insert="${idx}">
      <button class="strip-btn do-set-break" data-insert="${idx}">set break</button>
      <button class="strip-btn do-add-tune" data-insert="${idx}">+ tune</button>
    </div>`;
  }

  function bottomStripHTML(idx) {
    return `<div class="bottom-strip-inner">
      <button class="strip-btn do-set-break" data-insert="${idx}">set break</button>
      <button class="strip-btn do-add-tune" data-insert="${idx}">+ tune</button>
    </div>`;
  }

  // ── Render ──
  function render() {
    const hasItems = items.length > 0;
    clearRow.classList.toggle('hidden', !hasItems);

    if (!hasItems) {
      tuneLogEl.innerHTML = listening ? '<p class="text-muted text-sm italic py-4">Listening… no tunes detected yet.</p>' : '';
      bottomStrip.classList.toggle('hidden', !listening);
      bottomStrip.innerHTML = listening ? bottomStripHTML(0) : '';
      bindStrip(bottomStrip);
      return;
    }

    let html = '';
    items.forEach((item, idx) => {
      if (idx > 0) html += stripHTML(idx);

      if (item.type === 'divider') {
        html += `<div class="divider-row" data-idx="${idx}">
          <div class="divider-line"></div>
          <span class="divider-label">set break</span>
          <div class="divider-line"></div>
          <button class="icon-btn tune-delete" data-idx="${idx}" title="Remove">✕</button>
        </div>`;
        return;
      }

      const link = item.url
        ? `<a href="${item.url}" target="_blank" rel="noopener" class="tune-link">${esc(item.name)}</a>`
        : `<span class="italic">${esc(item.name)}</span>`;

      const score = item.score != null
        ? `<span class="tune-score">${(item.score * 100).toFixed(0)}%</span>`
        : `<span class="tune-manual-tag">manual</span>`;

      const hasAlts = item.alternatives?.length > 0;
      const swapBtn = hasAlts ? `<button class="icon-btn swap-btn" data-idx="${idx}" title="Alternatives">▾</button>` : '';

      html += `<div class="tune-row" data-idx="${idx}">
        <span class="text-muted text-xs" style="width:1.25rem;text-align:right;flex-shrink:0">${tuneNumber(idx)}</span>
        <span class="text-sm flex-1">${link}${score}${swapBtn}</span>
        <span class="tune-actions">
          <button class="icon-btn tune-delete" data-idx="${idx}" title="Remove">✕</button>
        </span>
      </div>
      <div id="alts-${idx}" class="hidden"></div>`;
    });

    tuneLogEl.innerHTML = html;

    bottomStrip.classList.remove('hidden');
    bottomStrip.innerHTML = bottomStripHTML(items.length);

    bindAll();
  }

  function bindStrip(container) {
    container.querySelectorAll('.do-set-break').forEach(el => {
      el.addEventListener('click', () => {
        const idx = parseInt(el.dataset.insert);
        if (items[idx - 1]?.type === 'divider' || items[idx]?.type === 'divider') return;
        items.splice(idx, 0, { type: 'divider' });
        render();
      });
    });
    container.querySelectorAll('.do-add-tune').forEach(el => {
      el.addEventListener('click', () => inlineInput(el, parseInt(el.dataset.insert)));
    });
  }

  function inlineInput(anchor, idx) {
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'inline-input';
    input.placeholder = 'Tune name…';
    anchor.replaceWith(input);
    input.focus();
    const commit = () => {
      const name = input.value.trim();
      if (name) items.splice(idx, 0, { type: 'tune', name, manual: true });
      render();
    };
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); commit(); }
      if (e.key === 'Escape') render();
    });
    input.addEventListener('blur', commit);
  }

  function bindAll() {
    tuneLogEl.querySelectorAll('.tune-delete').forEach(el =>
      el.addEventListener('click', () => { items.splice(parseInt(el.dataset.idx), 1); render(); }));
    tuneLogEl.querySelectorAll('.swap-btn').forEach(el =>
      el.addEventListener('click', () => toggleAlts(parseInt(el.dataset.idx))));
    bindStrip(tuneLogEl);
    bindStrip(bottomStrip);
  }

  function toggleAlts(idx) {
    const el = document.getElementById(`alts-${idx}`);
    if (!el) return;
    const item = items[idx];
    if (!item.alternatives?.length) return;
    if (!el.classList.contains('hidden')) { el.classList.add('hidden'); el.innerHTML = ''; return; }
    el.innerHTML = `<div class="alts-panel">${item.alternatives.map((a, ai) =>
      `<button class="alt-pick" data-idx="${idx}" data-alt="${ai}">→ ${esc(a.name)} <span style="color:var(--color-muted)">${(a.score * 100).toFixed(0)}%</span></button>`
    ).join('')}</div>`;
    el.classList.remove('hidden');
    el.querySelectorAll('.alt-pick').forEach(btn => {
      btn.addEventListener('click', () => {
        const ai = parseInt(btn.dataset.alt), alt = item.alternatives[ai];
        const old = { tuneId: item.tuneId, name: item.name, score: item.score, url: item.url };
        const alts = [...item.alternatives]; alts.splice(ai, 1); alts.unshift(old);
        items[idx] = { type: 'tune', tuneId: alt.tuneId, name: alt.name, score: alt.score, url: alt.url, alternatives: alts };
        render();
      });
    });
  }

  // ── Results ──
  function handleResults(results, contour) {
    if (!results?.length) { updateDebug('no results'); return; }
    const minScore = parseFloat(minScoreInput.value) || 0.25;
    const top = results[0];
    updateDebug(`${top.display_name} (${(top.score * 100).toFixed(0)}%)`);
    if (top.score < minScore) return;
    const tuneId = top.setting.tune_id;
    for (let i = items.length - 1; i >= 0; i--) {
      if (items[i].type === 'tune') {
        if (items[i].tuneId === tuneId) { if (top.score > (items[i].score || 0)) items[i].score = top.score; render(); return; }
        break;
      }
    }
    items.push({
      type: 'tune', tuneId, name: top.display_name, score: top.score,
      url: `https://thesession.org/tunes/${tuneId}`,
      alternatives: results.slice(1, 4).map(r => ({ tuneId: r.setting.tune_id, name: r.display_name, score: r.score, url: `https://thesession.org/tunes/${r.setting.tune_id}` })),
    });
    render();
    tuneLogEl.lastElementChild?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Audio ──
  async function startListening() {
    setStatus('Loading WASM…'); framesSent = 0; queriesSent = 0;
    debugEl.classList.remove('hidden'); updateDebug('—');
    worker = new Worker('/listen/listen-worker.js', { type: 'module' });
    worker.onmessage = ({ data }) => {
      if (data.type === 'status') setStatus(data.msg);
      if (data.type === 'ready') { workerReady = true; setStatus('Listening…'); startQueryLoop(); }
      if (data.type === 'results') { queriesSent++; handleResults(data.results, data.contour); }
      if (data.type === 'no-match') { queriesSent++; updateDebug(`no match: ${data.reason}`); }
      if (data.type === 'error') setStatus(`Error: ${data.msg}`);
    };
    worker.onerror = (e) => setStatus(`Worker error: ${e.message}`);
    try { micStream = await navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: false } }); }
    catch { setStatus('Mic access denied'); return; }
    audioCtx = new AudioContext();
    worker.postMessage({ type: 'init', sampleRate: audioCtx.sampleRate });
    const src = audioCtx.createMediaStreamSource(micStream);
    const proc = audioCtx.createScriptProcessor(1024, 1, 1);
    proc.onaudioprocess = (e) => {
      if (!workerReady) return;
      worker.postMessage({ type: 'audio', pcm: new Float32Array(e.inputBuffer.getChannelData(0)) });
      framesSent++; if (framesSent % 50 === 0) updateDebug();
    };
    src.connect(proc); proc.connect(audioCtx.destination);
    listening = true; btn.textContent = 'Stop Listening'; render();
  }

  function startQueryLoop() {
    const s = parseInt(intervalSel.value) || 15;
    queryTimer = setInterval(() => { if (workerReady) worker.postMessage({ type: 'query' }); }, s * 1000);
  }

  function stopListening() {
    if (queryTimer) clearInterval(queryTimer);
    if (micStream) micStream.getTracks().forEach(t => t.stop());
    if (audioCtx) audioCtx.close();
    if (worker) worker.terminate();
    worker = null; audioCtx = null; micStream = null; workerReady = false; listening = false;
    btn.textContent = 'Start Listening';
    setStatus(items.length ? `Stopped — ${items.filter(i => i.type === 'tune').length} tune(s)` : 'Stopped');
    render();
  }

  btn.addEventListener('click', () => listening ? stopListening() : startListening());
  btnClear.addEventListener('click', () => { if (items.length && !confirm('Clear all items?')) return; items = []; render(); });
</script>
