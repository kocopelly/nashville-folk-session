---
pagination:
  data: seriesList
  size: 1
  alias: s
permalink: "series/{{ s.id }}/index.html"
layout: base.njk
eleventyComputed:
  title: "{{ s.name }} — Nashville Folk Session"
---

<div class="mb-6">
  <a href="/" class="text-xs uppercase tracking-widest text-muted hover:text-ink transition-colors">← All Sessions</a>
</div>

<div class="flex flex-wrap items-baseline gap-3 mb-2">
  <h1 class="font-display text-3xl font-bold">{{ s.name }}</h1>
  {% if s.tradition %}
    <span class="badge-{{ s.tradition }} text-xs font-bold uppercase tracking-widest px-2 py-0.5 rounded-sm">{{ s.tradition }}</span>
  {% endif %}
</div>

{# ─── Series info card ─── #}
<div class="border border-border rounded-sm p-5 mb-8 bg-surface">
  <dl class="text-sm grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
    {% if s.venue %}
      <dt class="font-medium text-ink">Venue</dt>
      <dd class="text-muted">{{ s.venue }}{% if s.location %}, {{ s.location }}{% endif %}</dd>
    {% endif %}
    {% if s.schedule %}
      <dt class="font-medium text-ink">Schedule</dt>
      <dd class="text-muted">{{ s.schedule }}</dd>
    {% endif %}
    {% if s.organizer %}
      <dt class="font-medium text-ink">Led by</dt>
      <dd class="text-muted">{{ s.organizer }}</dd>
    {% endif %}
    {% set seriesSessions = sessions | seriesSessionCount(s.id) %}
    {% if seriesSessions > 0 %}
      <dt class="font-medium text-ink">Sessions logged</dt>
      <dd class="text-muted">{{ seriesSessions }}</dd>
    {% endif %}
  </dl>

  {% if s.description %}
    <p class="text-sm text-muted mt-4 pt-4 border-t border-border">{{ s.description }}</p>
  {% endif %}

  {% if s.links and s.links.length %}
    <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-border">
      {% for link in s.links %}
        <a href="{{ link.url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs uppercase tracking-widest px-3 py-1 border border-border text-ink bg-bg hover:border-ink transition-colors">{{ link.type | linkIcon | safe }} {{ link.label }}</a>
      {% endfor %}
    </div>
  {% endif %}
</div>

{# ─── Series feed ─── #}
{% set seriesFeed = feeds | feedsBySeries(s.id) %}
{% if seriesFeed.length > 0 %}
  <h2 class="font-display text-xl font-bold mb-4">Feed</h2>
  <div class="space-y-4 mb-8">
    {% for post in seriesFeed %}
      {% include "feed-post.njk" %}
    {% endfor %}
  </div>
{% endif %}

{# ─── Session list ─── #}
{% set seriesSessionList = sessions | filterBySeries(s.id) %}
{% if seriesSessionList.length > 0 %}
  <h2 class="font-display text-xl font-bold mb-4">Sessions</h2>
  <div class="space-y-4">
    {% for session in seriesSessionList | reverse %}
      {% set isAllLoose = session.sets | allLoose %}
      <a href="/sessions/{{ session.id }}/" class="block border-l-2 border-border hover:border-accent pl-4 py-2 transition-colors group">
        <div class="flex items-baseline gap-3">
          <span class="font-display font-bold text-ink group-hover:text-accent transition-colors">{{ session.date | dateDisplay }}</span>
          <span class="text-xs text-muted">
            {% if isAllLoose %}{{ session.sets | tuneCount }} tunes{% else %}{{ session.sets.length }} sets{% endif %}
          </span>
        </div>
        {% if session.notes %}
          <div class="text-xs text-muted mt-0.5">{{ session.notes }}</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>
{% else %}
  <p class="text-muted text-sm">No sessions logged yet for this series.</p>
{% endif %}
